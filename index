  const [form,setForm]=useState({title:trip?.title||"",type:trip?.type||"flight",status:trip?.status||"planning",start:trip?.start||"",end:trip?.end||"",budget:trip?.budget||0,cover:trip?.cover||"🌍"});
  useEffect(()=>{if(trip)setForm({title:trip.title,type:trip.type,status:trip.status,start:trip.start,end:trip.end,budget:trip.budget,cover:trip.cover})},[trip]);
  const covers=["🌍","🇳🇴","🇮🇹","🇪🇸","🇫🇷","🇬🇷","🇵🇹","🇩🇪","🇬🇧","🇯🇵","🇺🇸","🇨🇿","🇭🇷","🇮🇸","🏔️","🏖️","🌋","🗻"];
  return<Modal open={open} onClose={onClose} title={trip?"Modifica viaggio":"Nuovo viaggio"}>
    <div style={{display:"flex",flexDirection:"column",gap:12}}>
      <div><label style={{fontSize:12,color:"var(--color-text-secondary)",display:"block",marginBottom:4}}>Titolo</label><Input value={form.title} onChange={v=>setForm({...form,title:v})} placeholder="Es: Norvegia in camper"/></div>
      <div><label style={{fontSize:12,color:"var(--color-text-secondary)",display:"block",marginBottom:4}}>Icona</label><div style={{display:"flex",gap:4,flexWrap:"wrap"}}>{covers.map(c=><button key={c} onClick={()=>setForm({...form,cover:c})} style={{width:36,height:36,borderRadius:8,border:form.cover===c?`2px solid ${C.brand}`:"0.5px solid var(--color-border-tertiary)",background:form.cover===c?C.brandL:"var(--color-background-secondary)",fontSize:18,cursor:"pointer"}}>{c}</button>)}</div></div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
        <div><label style={{fontSize:12,color:"var(--color-text-secondary)",display:"block",marginBottom:4}}>Tipo</label><Select value={form.type} onChange={v=>setForm({...form,type:v})} options={Object.entries(TYPES).map(([k,v])=>({v:k,l:v.i+" "+v.l}))}/></div>
        <div><label style={{fontSize:12,color:"var(--color-text-secondary)",display:"block",marginBottom:4}}>Stato</label><Select value={form.status} onChange={v=>setForm({...form,status:v})} options={Object.entries(STAT).map(([k,v])=>({v:k,l:v.l}))}/></div>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
        <div><label style={{fontSize:12,color:"var(--color-text-secondary)",display:"block",marginBottom:4}}>Data partenza</label><Input type="date" value={form.start} onChange={v=>setForm({...form,start:v})}/></div>
        <div><label style={{fontSize:12,color:"var(--color-text-secondary)",display:"block",marginBottom:4}}>Data ritorno</label><Input type="date" value={form.end} onChange={v=>setForm({...form,end:v})}/></div>
      </div>
      <div><label style={{fontSize:12,color:"var(--color-text-secondary)",display:"block",marginBottom:4}}>Budget (€)</label><Input type="number" value={form.budget} onChange={v=>setForm({...form,budget:Number(v)})}/></div>
      <div style={{display:"flex",gap:8,marginTop:8}}><Btn primary full onClick={()=>{onSave(form);onClose()}}>Salva</Btn><Btn full onClick={onClose}>Annulla</Btn></div>
    </div>
  </Modal>;
}

/* ═══════════ TRIP DETAIL ═══════════ */
function TripDetail({trip,setView,expenses,setExpenses,members,tier,onEdit,onUpdateTrip}){
  const [tab,setTab]=useState("itinerary");
  const [chatInput,setChatInput]=useState("");
  const [chatMsgs,setChatMsgs]=useState(trip.chat);
  const [reminders,setReminders]=useState(trip.reminders);
  const [expModal,setExpModal]=useState(false);
  const [editExp,setEditExp]=useState(null);
  const chatEnd=useRef(null);
  const tripExp=expenses.filter(e=>e.tripId===trip.id);
  const totalSpent=tripExp.reduce((s,e)=>s+e.amount,0);

  useEffect(()=>{if(chatEnd.current)chatEnd.current.scrollIntoView({behavior:"smooth"})},[chatMsgs]);

  const actColors={transport:C.sky,activity:C.sea,food:C.sun,stay:C.plum};

  const sendChat=()=>{if(!chatInput.trim())return;setChatMsgs([...chatMsgs,{id:uid(),sender:"u1",text:chatInput,time:new Date().toLocaleTimeString("it-IT",{hour:"2-digit",minute:"2-digit"})}]);setChatInput("")};

  /* Expense split calc */
  const balances={};
  trip.members.forEach(id=>{balances[id]=0});
  tripExp.forEach(e=>{
    const share=e.amount/e.split.length;
    balances[e.paidBy]=(balances[e.paidBy]||0)+e.amount;
    e.split.forEach(id=>{balances[id]=(balances[id]||0)-share});
  });
  const debts=[];
  const debtors=Object.entries(balances).filter(([,v])=>v<-0.01).map(([id,v])=>({id,amount:-v})).sort((a,b)=>b.amount-a.amount);
  const creditors=Object.entries(balances).filter(([,v])=>v>0.01).map(([id,v])=>({id,amount:v})).sort((a,b)=>b.amount-a.amount);
  let di=0,ci=0;
  const dd=[...debtors.map(d=>({...d}))],cc=[...creditors.map(c=>({...c}))];
  while(di<dd.length&&ci<cc.length){
    const pay=Math.min(dd[di].amount,cc[ci].amount);
    if(pay>0.01)debts.push({from:dd[di].id,to:cc[ci].id,amount:Math.round(pay*100)/100});
    dd[di].amount-=pay;cc[ci].amount-=pay;
    if(dd[di].amount<0.01)di++;
    if(cc[ci].amount<0.01)ci++;
  }

  const saveExpense=(data)=>{
    if(editExp){
      setExpenses(expenses.map(e=>e.id===editExp.id?{...e,...data}:e));
    } else {
      setExpenses([...expenses,{id:uid(),tripId:trip.id,...data}]);
    }
    setEditExp(null);
  };

  const deleteExpense=(id)=>setExpenses(expenses.filter(e=>e.id!==id));

  const tabList=[
    {id:"itinerary",l:"Itinerario",i:"◈"},
    {id:"expenses",l:"Spese",i:"◆"},
    {id:"reminders",l:"Promemoria",i:"◇"},
    {id:"tickets",l:"Biglietti",i:"▤"},
    {id:"chat",l:"Chat",i:"◎"},
  ];

  return<div>
    <button onClick={()=>setView(null)} style={{background:"none",border:"none",cursor:"pointer",fontSize:13,color:"var(--color-text-secondary)",marginBottom:10,padding:0}}>← Torna ai viaggi</button>

    {/* Header */}
    <div style={{background:"var(--color-background-secondary)",borderRadius:16,padding:"16px 18px",marginBottom:14}}>
      <div style={{display:"flex",gap:14,alignItems:"center"}}>
        <div style={{width:54,height:54,borderRadius:16,background:"var(--color-background-primary)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:28,border:"0.5px solid var(--color-border-tertiary)"}}>{trip.cover}</div>
        <div style={{flex:1,minWidth:0}}>
          <div style={{display:"flex",alignItems:"center",gap:8}}><div style={{fontSize:18,fontWeight:500}}>{trip.title}</div><button onClick={onEdit} style={{background:"none",border:"none",cursor:"pointer",fontSize:14,color:"var(--color-text-secondary)"}}>✏️</button></div>
          <div style={{fontSize:12,color:"var(--color-text-secondary)",marginTop:3}}>{fmtD(trip.start)} → {fmtD(trip.end)} · {daysB(trip.start,trip.end)}gg</div>
          <div style={{display:"flex",gap:5,marginTop:6,alignItems:"center",flexWrap:"wrap"}}><Pill color={TYPES[trip.type].c} s>{TYPES[trip.type].i} {TYPES[trip.type].l}</Pill><Pill color={STAT[trip.status].c} bg={STAT[trip.status].bg} s>{STAT[trip.status].l}</Pill><AvStack ids={trip.members} sz={18} members={members}/></div>
        </div>
        <div style={{textAlign:"right"}}><div style={{fontSize:12,color:"var(--color-text-secondary)"}}>Budget</div><div style={{fontSize:18,fontWeight:500}}>€{trip.budget}</div><div style={{fontSize:11,color:C.sea}}>€{totalSpent} spesi</div></div>
      </div>
      <div style={{marginTop:12}}><div style={{height:5,borderRadius:3,background:"var(--color-border-tertiary)"}}><div style={{height:5,borderRadius:3,background:totalSpent>trip.budget?C.brand:C.sea,width:`${Math.min((totalSpent/trip.budget)*100,100)}%`}}/></div><div style={{display:"flex",justifyContent:"space-between",fontSize:10,color:"var(--color-text-tertiary)",marginTop:3}}><span>{Math.round(totalSpent/trip.budget*100)}% usato</span><span>€{trip.budget-totalSpent} rimanenti</span></div></div>
    </div>

    <Tabs tabs={tabList} active={tab} onChange={setTab}/>

    {/* ── ITINERARY ── */}
    {tab==="itinerary"&&<div>
      {trip.days.length===0?<EmptyState icon="🗺️" title="Nessun itinerario" sub="Inizia a pianificare aggiungendo i giorni" action="+ Aggiungi giorno" onAction={()=>{}}/>:
      <div style={{display:"flex",flexDirection:"column",gap:10}}>
        {trip.days.map((day,di)=><Card key={di}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
            <div style={{display:"flex",gap:8,alignItems:"center"}}>
              <div style={{width:30,height:30,borderRadius:8,background:C.brandL,display:"flex",alignItems:"center",justifyContent:"center",fontSize:12,fontWeight:500,color:C.brand}}>G{di+1}</div>
              <div><div style={{fontSize:14,fontWeight:500}}>{day.title}</div><div style={{fontSize:11,color:"var(--color-text-secondary)"}}>{fmtD(day.date)}</div></div>
            </div>
            <div style={{fontSize:11,color:"var(--color-text-tertiary)"}}>{day.acts.length} att. · €{day.acts.reduce((s,a)=>s+a.cost,0)}</div>
          </div>
          <div style={{paddingLeft:18,position:"relative"}}>
            <div style={{position:"absolute",left:5,top:4,bottom:4,width:1.5,background:"var(--color-border-tertiary)",borderRadius:1}}/>
            {day.acts.map((act,ai)=><div key={ai} style={{display:"flex",gap:10,marginBottom:ai<day.acts.length-1?12:0,position:"relative"}}>
              <div style={{width:12,height:12,borderRadius:"50%",background:actColors[act.type]||C.stone,border:"2px solid var(--color-background-primary)",position:"relative",zIndex:1,marginTop:3,flexShrink:0}}/>
              <div style={{flex:1,minWidth:0}}>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start"}}>
                  <div><div style={{fontSize:13,fontWeight:500}}><span style={{marginRight:4}}>{act.icon}</span>{act.name}</div>{act.notes&&<div style={{fontSize:11,color:"var(--color-text-secondary)",marginTop:2}}>{act.notes}</div>}</div>
                  <div style={{textAlign:"right",flexShrink:0,marginLeft:8}}><div style={{fontSize:12,fontWeight:500,color:"var(--color-text-secondary)"}}>{act.time}</div>{act.cost>0&&<div style={{fontSize:11,color:C.sea}}>€{act.cost}</div>}</div>
                </div>
              </div>
            </div>)}
          </div>
        </Card>)}
        <button style={{padding:12,borderRadius:12,border:"1.5px dashed var(--color-border-secondary)",background:"transparent",color:"var(--color-text-secondary)",fontSize:13,cursor:"pointer"}}>+ Aggiungi giorno</button>
      </div>}
    </div>}

    {/* ── EXPENSES + SPLIT ── */}
    {tab==="expenses"&&<div>
      {/* Summary */}
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8,marginBottom:14}}>
        <div style={{background:"var(--color-background-secondary)",borderRadius:10,padding:"10px 12px"}}><div style={{fontSize:10,color:"var(--color-text-secondary)"}}>Totale spese</div><div style={{fontSize:18,fontWeight:500}}>€{totalSpent}</div></div>
        <div style={{background:"var(--color-background-secondary)",borderRadius:10,padding:"10px 12px"}}><div style={{fontSize:10,color:"var(--color-text-secondary)"}}>Budget</div><div style={{fontSize:18,fontWeight:500}}>€{trip.budget}</div></div>
        <div style={{background:"var(--color-background-secondary)",borderRadius:10,padding:"10px 12px"}}><div style={{fontSize:10,color:"var(--color-text-secondary)"}}>Rimanente</div><div style={{fontSize:18,fontWeight:500,color:trip.budget-totalSpent>=0?C.sea:C.brand}}>€{trip.budget-totalSpent}</div></div>
      </div>

      {/* Category breakdown */}
      <Card style={{marginBottom:14}}>
        <div style={{fontSize:13,fontWeight:500,marginBottom:10}}>Spese per categoria</div>
        {Object.entries(EXP_CAT).map(([k,v])=>{
          const catTotal=tripExp.filter(e=>e.cat===k).reduce((s,e)=>s+e.amount,0);
          if(catTotal===0)return null;
          return<div key={k} style={{display:"flex",alignItems:"center",gap:8,padding:"6px 0",borderBottom:"0.5px solid var(--color-border-tertiary)"}}>
            <span style={{fontSize:14}}>{v.i}</span><span style={{fontSize:12,flex:1}}>{v.l}</span>
            <div style={{width:100,height:5,borderRadius:3,background:"var(--color-background-secondary)"}}><div style={{height:5,borderRadius:3,background:v.c,width:`${Math.min(catTotal/totalSpent*100,100)}%`}}/></div>
            <span style={{fontSize:12,fontWeight:500,minWidth:50,textAlign:"right"}}>€{catTotal}</span>
          </div>;
        })}
      </Card>

      {/* Expense list */}
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
        <div style={{fontSize:14,fontWeight:500}}>Tutte le spese</div>
        <Btn primary small onClick={()=>{setEditExp(null);setExpModal(true)}}>+ Nuova spesa</Btn>
      </div>
      <div style={{display:"flex",flexDirection:"column",gap:6,marginBottom:16}}>
        {tripExp.length===0?<EmptyState icon="💸" title="Nessuna spesa" sub="Aggiungi la prima spesa del viaggio"/>:
        tripExp.map(e=>{
          const payer=gM(e.paidBy,members);
          const cat=EXP_CAT[e.cat]||EXP_CAT.other;
          return<Card key={e.id} style={{padding:"12px 14px"}}>
            <div style={{display:"flex",gap:10,alignItems:"center"}}>
              <div style={{width:38,height:38,borderRadius:10,background:cat.c+"18",display:"flex",alignItems:"center",justifyContent:"center",fontSize:16}}>{cat.i}</div>
              <div style={{flex:1,minWidth:0}}>
                <div style={{fontSize:13,fontWeight:500}}>{e.desc}</div>
                <div style={{display:"flex",gap:6,marginTop:3,alignItems:"center",flexWrap:"wrap"}}>
                  <div style={{display:"flex",gap:3,alignItems:"center"}}><Av m={e.paidBy} sz={16} members={members}/><span style={{fontSize:11,color:"var(--color-text-secondary)"}}>pagato da {payer.name}</span></div>
                  <span style={{fontSize:10,color:"var(--color-text-tertiary)"}}>·</span>
                  <span style={{fontSize:11,color:"var(--color-text-tertiary)"}}>{fmtD(e.date)}</span>
                  {e.split.length>1&&<Pill color={C.plumD} bg={C.plumL} s>÷{e.split.length}</Pill>}
                </div>
              </div>
              <div style={{textAlign:"right"}}>
                <div style={{fontSize:15,fontWeight:500}}>€{e.amount}</div>
                {e.split.length>1&&<div style={{fontSize:10,color:"var(--color-text-tertiary)"}}>€{Math.round(e.amount/e.split.length*100)/100}/pers</div>}
              </div>
              <div style={{display:"flex",flexDirection:"column",gap:2}}>
                <button onClick={()=>{setEditExp(e);setExpModal(true)}} style={{background:"none",border:"none",cursor:"pointer",fontSize:11,color:"var(--color-text-secondary)",padding:"2px 4px"}}>✏️</button>
                <button onClick={()=>deleteExpense(e.id)} style={{background:"none",border:"none",cursor:"pointer",fontSize:11,color:C.brand,padding:"2px 4px"}}>🗑️</button>
              </div>
            </div>
          </Card>;
        })}
      </div>

      {/* SPLIT / BALANCES — Premium */}
      {tier==="free"?<PremiumLock feature="Divisione spese e saldi"/>:
      <Card style={{borderTop:`3px solid ${C.plum}`}}>
        <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:14}}><span style={{fontSize:14}}>⚖️</span><div style={{fontSize:14,fontWeight:500}}>Divisione spese</div><Pill color={C.plumD} bg={C.plumL} s>Split</Pill></div>

        {/* Balances */}
        <div style={{marginBottom:16}}>
          <div style={{fontSize:12,color:"var(--color-text-secondary)",marginBottom:8}}>Bilancio per persona</div>
          {trip.members.map(id=>{
            const m=gM(id,members);
            const bal=Math.round((balances[id]||0)*100)/100;
            const paid=tripExp.filter(e=>e.paidBy===id).reduce((s,e)=>s+e.amount,0);
            const owes=tripExp.filter(e=>e.split.includes(id)).reduce((s,e)=>s+e.amount/e.split.length,0);
            return<div key={id} style={{display:"flex",gap:10,alignItems:"center",padding:"8px 0",borderBottom:"0.5px solid var(--color-border-tertiary)"}}>
              <Av m={m} sz={28} members={members}/>
              <div style={{flex:1}}><div style={{fontSize:13,fontWeight:500}}>{m.name}</div><div style={{fontSize:11,color:"var(--color-text-tertiary)"}}>Pagato €{paid} · Quota €{Math.round(owes*100)/100}</div></div>
              <div style={{textAlign:"right"}}><div style={{fontSize:14,fontWeight:500,color:bal>=0?C.sea:C.brand}}>{bal>=0?"+":""}€{bal}</div><div style={{fontSize:10,color:"var(--color-text-tertiary)"}}>{bal>=0?"in credito":"in debito"}</div></div>
            </div>;
          })}
        </div>

        {/* Settlements */}
        {debts.length>0&&<div>
          <div style={{fontSize:12,color:"var(--color-text-secondary)",marginBottom:8}}>Per pareggiare i conti</div>
          {debts.map((d,i)=>{
            const from=gM(d.from,members),to=gM(d.to,members);
            return<div key={i} style={{display:"flex",alignItems:"center",gap:8,padding:"10px 12px",background:"var(--color-background-secondary)",borderRadius:10,marginBottom:6}}>
              <Av m={from} sz={24} members={members}/>
              <span style={{fontSize:12,fontWeight:500}}>{from.name}</span>
              <span style={{fontSize:11,color:"var(--color-text-tertiary)",flex:1,textAlign:"center"}}>deve pagare</span>
              <span style={{fontSize:14,fontWeight:500,color:C.brand}}>€{d.amount}</span>
              <span style={{fontSize:11,color:"var(--color-text-tertiary)"}}>a</span>
              <span style={{fontSize:12,fontWeight:500}}>{to.name}</span>
              <Av m={to} sz={24} members={members}/>
            </div>;
          })}
        </div>}
        {debts.length===0&&<div style={{textAlign:"center",padding:"1rem",fontSize:13,color:C.sea}}>Tutti i conti sono pari!</div>}
      </Card>}

      {/* Expense Modal */}
      <ExpenseModal open={expModal} onClose={()=>{setExpModal(false);setEditExp(null)}} onSave={saveExpense} expense={editExp} members={members} tripMembers={trip.members}/>
    </div>}

    {/* ── REMINDERS ── */}
    {tab==="reminders"&&<Card>
      {reminders.length===0?<div style={{textAlign:"center",padding:"2rem",color:"var(--color-text-secondary)",fontSize:13}}>Nessun promemoria</div>:
      reminders.map((r,i)=><div key={r.id} style={{display:"flex",gap:10,alignItems:"center",padding:"10px 0",borderBottom:i<reminders.length-1?"0.5px solid var(--color-border-tertiary)":"none"}}>
        <button onClick={()=>setReminders(reminders.map(x=>x.id===r.id?{...x,done:!x.done}:x))} style={{width:20,height:20,borderRadius:6,border:r.done?"none":`1.5px solid var(--color-border-secondary)`,background:r.done?C.sea:"transparent",cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",color:"#fff",fontSize:11,flexShrink:0}}>{r.done?"✓":""}</button>
        <div style={{flex:1}}><div style={{fontSize:13,textDecoration:r.done?"line-through":"none",color:r.done?"var(--color-text-tertiary)":"var(--color-text-primary)"}}>{r.text}</div><div style={{fontSize:11,color:"var(--color-text-tertiary)"}}>{fmtD(r.date)}</div></div>
        <button onClick={()=>setReminders(reminders.filter(x=>x.id!==r.id))} style={{background:"none",border:"none",cursor:"pointer",fontSize:11,color:"var(--color-text-tertiary)"}}>🗑️</button>
      </div>)}
      <button style={{width:"100%",marginTop:12,padding:10,borderRadius:10,border:"1.5px dashed var(--color-border-secondary)",background:"transparent",color:"var(--color-text-secondary)",fontSize:12,cursor:"pointer"}}>+ Nuovo promemoria</button>
    </Card>}

    {/* ── TICKETS ── */}
    {tab==="tickets"&&<div style={{display:"flex",flexDirection:"column",gap:8}}>
      {trip.tickets.length===0?<EmptyState icon="🎫" title="Nessun biglietto" sub="Aggiungi voli, prenotazioni, ingressi" action="+ Aggiungi biglietto"/>:
      trip.tickets.map(tk=><Card key={tk.id}><div style={{display:"flex",gap:12,alignItems:"center"}}>
        <div style={{width:42,height:42,borderRadius:12,background:tk.ttype==="flight"?C.plumL:tk.ttype==="vehicle"?C.seaL:C.sunL,display:"flex",alignItems:"center",justifyContent:"center",fontSize:18}}>{tk.ttype==="flight"?"✈️":tk.ttype==="vehicle"?"🚐":"🎟️"}</div>
        <div style={{flex:1}}><div style={{fontSize:14,fontWeight:500}}>{tk.name}</div><div style={{display:"flex",gap:6,marginTop:3,alignItems:"center"}}><span style={{fontFamily:"monospace",fontSize:11,padding:"2px 7px",borderRadius:4,background:"var(--color-background-secondary)",fontWeight:500}}>{tk.code}</span><span style={{fontSize:11,color:"var(--color-text-secondary)"}}>{fmtD(tk.date)}</span></div></div>
        <Pill color={tk.status==="confirmed"?C.seaD:C.sunD} bg={tk.status==="confirmed"?C.seaL:C.sunL}>{tk.status==="confirmed"?"✓ Confermato":"◷ In attesa"}</Pill>
      </div></Card>)}
      <button style={{padding:12,borderRadius:12,border:"1.5px dashed var(--color-border-secondary)",background:"transparent",color:"var(--color-text-secondary)",fontSize:13,cursor:"pointer"}}>+ Aggiungi biglietto</button>
    </div>}

    {/* ── CHAT ── */}
    {tab==="chat"&&<Card style={{padding:0,overflow:"hidden"}}>
      <div style={{padding:"10px 14px",borderBottom:"0.5px solid var(--color-border-tertiary)",display:"flex",alignItems:"center",gap:8}}><AvStack ids={trip.members} sz={20} members={members}/><span style={{fontSize:13,fontWeight:500}}>Chat del viaggio</span></div>
      <div style={{padding:14,maxHeight:280,overflowY:"auto",background:"var(--color-background-secondary)"}}>
        {chatMsgs.map(msg=>{const s=gM(msg.sender,members);const me=msg.sender==="u1";return<div key={msg.id} style={{display:"flex",gap:7,marginBottom:12,flexDirection:me?"row-reverse":"row"}}>
          <Av m={s} sz={26} members={members}/>
