/* ─── UTILS ─── */
const fmtD = d => new Date(d+"T00:00:00").toLocaleDateString("it-IT",{day:"numeric",month:"short"});
const fmtDL = d => new Date(d+"T00:00:00").toLocaleDateString("it-IT",{day:"numeric",month:"long",year:"numeric"});
const daysB = (a,b) => Math.ceil((new Date(b)-new Date(a))/864e5)+1;
const gM = (id,members) => members.find(m=>m.id===id)||members[0];
const uid = () => Date.now().toString(36)+Math.random().toString(36).slice(2,6);

/* ─── TINY UI ─── */
const Pill = ({children,color,bg,s})=><span style={{fontSize:s?10:11,fontWeight:500,padding:s?"2px 7px":"3px 10px",borderRadius:6,background:bg||"var(--color-background-secondary)",color:color||"var(--color-text-secondary)",whiteSpace:"nowrap"}}>{children}</span>;

const Av = ({m,sz=28,members})=>{const mm=typeof m==="string"?gM(m,members):m;return<div style={{width:sz,height:sz,borderRadius:"50%",background:mm.c,display:"flex",alignItems:"center",justifyContent:"center",fontSize:sz*.38,fontWeight:500,color:"#fff",flexShrink:0}}>{mm.av||mm.name?.[0]}</div>};

const AvStack = ({ids,sz=22,members})=><div style={{display:"flex"}}>{ids.map((id,i)=><div key={id} style={{marginLeft:i?-7:0,zIndex:ids.length-i}}><Av m={id} sz={sz} members={members}/></div>)}</div>;

const Btn = ({children,onClick,primary,small,full,disabled,danger})=><button disabled={disabled} onClick={onClick} style={{padding:small?"6px 14px":"10px 20px",borderRadius:10,border:primary||danger?"none":"0.5px solid var(--color-border-secondary)",background:danger?C.brand:primary?C.brand:"var(--color-background-primary)",color:primary||danger?"#fff":"var(--color-text-secondary)",fontSize:small?12:13,fontWeight:500,cursor:disabled?"not-allowed":"pointer",opacity:disabled?.5:1,width:full?"100%":undefined,transition:"all .15s"}}>{children}</button>;

const Input = ({value,onChange,placeholder,type="text",style:s})=><input type={type} value={value} onChange={e=>onChange(e.target.value)} placeholder={placeholder} style={{width:"100%",padding:"9px 13px",borderRadius:10,border:"0.5px solid var(--color-border-tertiary)",background:"var(--color-background-secondary)",fontSize:13,outline:"none",color:"var(--color-text-primary)",boxSizing:"border-box",...s}}/>;

const Select = ({value,onChange,options})=><select value={value} onChange={e=>onChange(e.target.value)} style={{padding:"9px 13px",borderRadius:10,border:"0.5px solid var(--color-border-tertiary)",background:"var(--color-background-secondary)",fontSize:13,color:"var(--color-text-primary)",outline:"none",width:"100%"}}>{options.map(o=><option key={o.v} value={o.v}>{o.l}</option>)}</select>;

const Card = ({children,style,onClick})=><div onClick={onClick} style={{background:"var(--color-background-primary)",borderRadius:14,border:"0.5px solid var(--color-border-tertiary)",padding:"1rem 1.1rem",cursor:onClick?"pointer":"default",transition:"all .15s",...style}}>{children}</div>;

