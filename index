  const [editModal,setEditModal]=useState(false);
  const [editTrip,setEditTrip]=useState(null);

  const deleteTrip=(id)=>{setTrips(trips.filter(t=>t.id!==id));setExpenses(expenses.filter(e=>e.tripId!==id))};
  const newTrip=()=>{setEditTrip(null);setEditModal(true)};

  const saveTrip=(form)=>{
    if(editTrip){
      setTrips(trips.map(t=>t.id===editTrip.id?{...t,...form}:t));
    } else {
      setTrips([...trips,{id:uid(),days:[],reminders:[],tickets:[],chat:[],members:["u1"],...form}]);
    }
  };

  const handleEditFromDetail=()=>{
    const t=trips.find(t=>t.id===view);
    if(t){setEditTrip(t);setEditModal(true)}
  };

  // Handle edit view from trip list context menu
  useEffect(()=>{
    if(view&&view.endsWith("_edit")){
      const id=view.replace("_edit","");
      const t=trips.find(t=>t.id===id);
      if(t){setEditTrip(t);setEditModal(true);setView(id)}
    }
  },[view]);

  return<div style={{fontFamily:"var(--font-sans)",color:"var(--color-text-primary)",maxWidth:680,margin:"0 auto"}}>
    {/* Header */}
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"6px 0 10px"}}>
      <div style={{display:"flex",alignItems:"center",gap:8}}>
        <span style={{fontSize:22,fontWeight:600,color:C.brand,letterSpacing:-1}}>Roami</span>
        <Pill color={tier==="free"?C.stoneD:tier==="plus"?C.skyD:C.brandD} bg={tier==="free"?C.stoneL:tier==="plus"?C.skyL:C.brandL} s>{tier==="free"?"Free":tier==="plus"?"Plus":"Pro"}</Pill>
      </div>
      <Av m="u1" sz={30} members={members}/>
    </div>

    <NavBar page={page} setPage={setPage} setView={setView}/>

    <div style={{minHeight:500}}>
      {page==="home"&&<HomePage trips={trips} expenses={expenses} members={members} setPage={setPage} setView={setView} tier={tier}/>}
      {page==="trips"&&!view&&<TripList trips={trips} setView={setView} onNew={newTrip} onDelete={deleteTrip} members={members}/>}
      {page==="trips"&&view&&trips.find(t=>t.id===view)&&<TripDetail trip={trips.find(t=>t.id===view)} setView={setView} expenses={expenses} setExpenses={setExpenses} members={members} tier={tier} onEdit={handleEditFromDetail} onUpdateTrip={(updated)=>setTrips(trips.map(t=>t.id===updated.id?updated:t))}/>}
      {page==="calendar"&&<CalendarPage trips={trips}/>}
      {page==="expenses"&&<ExpensesPage trips={trips} expenses={expenses} members={members} tier={tier}/>}
      {page==="profile"&&<ProfilePage tier={tier} setTier={setTier} members={members}/>}
    </div>

    <TripEditModal trip={editTrip} open={editModal} onClose={()=>{setEditModal(false);setEditTrip(null)}} onSave={saveTrip}/>
  </div>;
}
