/* ═══════════ DASHBOARD ═══════════ */
function HomePage({trips,expenses,members,setPage,setView,tier}){
  const upcoming=trips.filter(t=>t.status!=="completed");
  const next=upcoming[0];
  const daysTo=next?daysB("2026-04-15",next.start):0;
  const totalPending=trips.flatMap(t=>t.reminders).filter(r=>!r.done).length;
  const totalExp=expenses.reduce((s,e)=>s+e.amount,0);

  return<div>
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:20}}>
      <div><h2 style={{fontSize:20,fontWeight:500,margin:0}}>Buongiorno, Matteo</h2><p style={{fontSize:13,color:"var(--color-text-secondary)",margin:"3px 0 0"}}>{upcoming.length} viaggi in programma</p></div>
      <Pill color={tier==="free"?C.stoneD:tier==="plus"?C.skyD:C.brandD} bg={tier==="free"?C.stoneL:tier==="plus"?C.skyL:C.brandL}>{tier==="free"?"Free":tier==="plus"?"Plus":"Pro"}</Pill>
    </div>

    <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:8,marginBottom:18}}>
      {[{l:"Partenza tra",v:`${daysTo}gg`,c:C.brand},{l:"Viaggi",v:upcoming.length,c:C.sea},{l:"Promemoria",v:totalPending,c:C.sun},{l:"Spese totali",v:`€${totalExp}`,c:C.sky}].map((s,i)=><div key={i} style={{background:"var(--color-background-secondary)",borderRadius:10,padding:"10px 12px"}}><div style={{fontSize:10,color:"var(--color-text-secondary)"}}>{s.l}</div><div style={{fontSize:18,fontWeight:500,color:s.c,marginTop:2}}>{s.v}</div></div>)}
    </div>

    {next&&<Card onClick={()=>{setView(next.id);setPage("trips")}} style={{marginBottom:16}}>
      <div style={{display:"flex",gap:12,alignItems:"center"}}>
        <div style={{width:50,height:50,borderRadius:14,background:C.seaL,display:"flex",alignItems:"center",justifyContent:"center",fontSize:26}}>{next.cover}</div>
        <div style={{flex:1,minWidth:0}}>
          <div style={{fontSize:15,fontWeight:500}}>{next.title}</div>
          <div style={{fontSize:12,color:"var(--color-text-secondary)",marginTop:2}}>{fmtD(next.start)} → {fmtD(next.end)} · {daysB(next.start,next.end)} giorni</div>
          <div style={{display:"flex",gap:5,marginTop:6,alignItems:"center"}}><Pill color={TYPES[next.type].c} s>{TYPES[next.type].i} {TYPES[next.type].l}</Pill><Pill color={STAT[next.status].c} bg={STAT[next.status].bg} s>{STAT[next.status].l}</Pill><AvStack ids={next.members} sz={18} members={members}/></div>
        </div>
        <div style={{textAlign:"right"}}><div style={{fontSize:22,fontWeight:500,color:C.brand}}>{daysTo}</div><div style={{fontSize:9,color:"var(--color-text-tertiary)"}}>giorni</div></div>
      </div>
    </Card>}

    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
      {trips.slice(1).map(t=><Card key={t.id} onClick={()=>{setView(t.id);setPage("trips")}} style={{padding:"12px"}}>
        <div style={{display:"flex",gap:8,alignItems:"center"}}>
          <div style={{width:36,height:36,borderRadius:10,background:TYPES[t.type].c+"18",display:"flex",alignItems:"center",justifyContent:"center",fontSize:18}}>{t.cover}</div>
          <div style={{flex:1,minWidth:0}}><div style={{fontSize:13,fontWeight:500,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{t.title}</div><div style={{fontSize:11,color:"var(--color-text-secondary)"}}>{fmtD(t.start)} · {TYPES[t.type].i}</div></div>
        </div>
      </Card>)}
    </div>
  </div>;
}

