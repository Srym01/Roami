/* ═══════════ CALENDAR ═══════════ */
function CalendarPage({trips}){
  const [month,setMonth]=useState(6);
  const [selDay,setSelDay]=useState(null);
  const ms=["Gennaio","Febbraio","Marzo","Aprile","Maggio","Giugno","Luglio","Agosto","Settembre","Ottobre","Novembre","Dicembre"];
  const yr=2026;
  const fd=new Date(yr,month,1).getDay();
  const dim=new Date(yr,month+1,0).getDate();
  const off=fd===0?6:fd-1;
  const pad=d=>String(d).padStart(2,"0");
  const ds=d=>`${yr}-${pad(month+1)}-${pad(d)}`;
  const tripOn=(d)=>trips.find(t=>ds(d)>=t.start&&ds(d)<=t.end);
  const remOn=(d)=>trips.flatMap(t=>t.reminders.filter(r=>r.date===ds(d)).map(r=>({...r,trip:t.title})));
  const isStart=(d)=>trips.some(t=>t.start===ds(d));
  const isEnd=(d)=>trips.some(t=>t.end===ds(d));

  return<div>
    <h2 style={{fontSize:20,fontWeight:500,margin:"0 0 16px"}}>Calendario</h2>
    <Card style={{marginBottom:14}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}>
        <button onClick={()=>setMonth(Math.max(0,month-1))} style={{background:"none",border:"none",cursor:"pointer",fontSize:16,color:"var(--color-text-secondary)"}}>←</button>
        <span style={{fontSize:15,fontWeight:500}}>{ms[month]} {yr}</span>
        <button onClick={()=>setMonth(Math.min(11,month+1))} style={{background:"none",border:"none",cursor:"pointer",fontSize:16,color:"var(--color-text-secondary)"}}>→</button>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"repeat(7,1fr)",gap:2}}>
        {["L","M","M","G","V","S","D"].map((d,i)=><div key={i} style={{textAlign:"center",fontSize:11,color:"var(--color-text-tertiary)",padding:"5px 0",fontWeight:500}}>{d}</div>)}
        {Array.from({length:off}).map((_,i)=><div key={`e${i}`}/>)}
        {Array.from({length:dim}).map((_,i)=>{
          const d=i+1;const trip=tripOn(d);const rems=remOn(d);const sel=selDay===d;const start=isStart(d);const end=isEnd(d);
          return<button key={d} onClick={()=>setSelDay(sel?null:d)} style={{aspectRatio:"1",borderRadius:10,border:"none",cursor:"pointer",background:sel?C.brand:trip?(TYPES[trip.type]?.c||C.sea)+"18":"transparent",color:sel?"#fff":"var(--color-text-primary)",fontSize:12,fontWeight:(start||end)?600:rems.length?500:400,position:"relative",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",gap:1}}>
            {d}
            {(rems.length>0||start||end)&&<div style={{display:"flex",gap:2}}>{rems.length>0&&<div style={{width:4,height:4,borderRadius:"50%",background:sel?"#fff":C.sun}}/>}{start&&<div style={{width:4,height:4,borderRadius:"50%",background:sel?"#fff":C.green}}/>}{end&&<div style={{width:4,height:4,borderRadius:"50%",background:sel?"#fff":C.brand}}/>}</div>}
          </button>;
        })}
      </div>
    </Card>
    {selDay&&<Card>
      <div style={{fontSize:14,fontWeight:500,marginBottom:10}}>{selDay} {ms[month]} {yr}</div>
      {tripOn(selDay)&&<div style={{display:"flex",gap:8,alignItems:"center",padding:"8px 10px",background:"var(--color-background-secondary)",borderRadius:10,marginBottom:8}}>
        <span style={{fontSize:16}}>{tripOn(selDay).cover}</span><div><div style={{fontSize:13,fontWeight:500}}>{tripOn(selDay).title}</div><div style={{fontSize:11,color:"var(--color-text-secondary)"}}>{isStart(selDay)?"Partenza":isEnd(selDay)?"Ritorno":"In viaggio"}</div></div>
      </div>}
      {remOn(selDay).map(r=><div key={r.id} style={{display:"flex",gap:8,alignItems:"center",padding:"6px 0"}}><div style={{width:6,height:6,borderRadius:"50%",background:C.sun}}/><span style={{fontSize:12}}>{r.text}</span><span style={{fontSize:10,color:"var(--color-text-tertiary)",marginLeft:"auto"}}>{r.trip}</span></div>)}
      {!tripOn(selDay)&&remOn(selDay).length===0&&<div style={{fontSize:13,color:"var(--color-text-tertiary)",textAlign:"center",padding:"0.5rem"}}>Nessun evento</div>}
    </Card>}
    <Card style={{marginTop:14}}><div style={{fontSize:13,fontWeight:500,marginBottom:8}}>Legenda</div>
      <div style={{display:"flex",gap:14,flexWrap:"wrap",fontSize:11,color:"var(--color-text-secondary)"}}>
        <span style={{display:"flex",alignItems:"center",gap:4}}><div style={{width:8,height:8,borderRadius:"50%",background:C.green}}/>Partenza</span>
        <span style={{display:"flex",alignItems:"center",gap:4}}><div style={{width:8,height:8,borderRadius:"50%",background:C.brand}}/>Ritorno</span>
        <span style={{display:"flex",alignItems:"center",gap:4}}><div style={{width:8,height:8,borderRadius:"50%",background:C.sun}}/>Promemoria</span>
      </div>
    </Card>
  </div>;
}

